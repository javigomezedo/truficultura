DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/trufiq
SECRET_KEY=change-me-in-production-please
LOG_LEVEL=INFO
LOG_JSON=0
METRICS_ENABLED=1
# Opcional: protege /metrics con este token en cabecera x-metrics-token
METRICS_TOKEN=
# Sentry (opcional): detalle de excepciones para diagnostico rapido
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0
# Asistente IA — Azure OpenAI (recomendado: datos en UE, no se usan para entrenamiento)
# Crea un recurso Azure OpenAI en https://portal.azure.com, despliega gpt-4o-mini
# y rellena las tres variables. Si están configuradas, Azure tiene prioridad sobre OPENAI_API_KEY.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=                 # ej. https://mi-recurso.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=               # nombre del deployment de chat, ej. trufiq-chat
AZURE_OPENAI_WHISPER_DEPLOYMENT=       # nombre del deployment de Whisper, ej. trufiq-whisper
AZURE_OPENAI_WHISPER_ENDPOINT=         # solo si Whisper está en un recurso distinto
AZURE_OPENAI_WHISPER_KEY=              # solo si Whisper tiene una API key distinta

# Asistente IA — OpenAI consumer (alternativa, los datos SÍ pueden usarse para entrenamiento)
# También necesario para la transcripción de voz (Whisper), independientemente del proveedor de chat.
OPENAI_API_KEY=

# Email — Postmark (proveedor principal, recomendado)
# Crea una cuenta en https://postmarkapp.com y añade tu API key de servidor.
# Con POSTMARK_API_KEY configurado no hacen falta las variables SMTP_*.
POSTMARK_API_KEY=
POSTMARK_FROM=hola@trufiq.app

# Email — SMTP (fallback / desarrollo con Mailtrap u otro sandbox)
# Se usa automáticamente si POSTMARK_API_KEY no está definido.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@trufiq.app

# Dirección de destino para notificaciones de leads (por defecto usa POSTMARK_FROM/SMTP_FROM)
CONTACT_EMAIL=

# Stripe (pago / suscripción)
# Para desarrollo local: usa test keys (sk_test_...) + Stripe CLI para webhooks
# Para DEV/Staging: usa test keys + registra el endpoint en Stripe Dashboard
# Para Production: usa live keys (sk_live_...)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_BASIC=price_XXXXXXXXXX_basic
STRIPE_PRICE_ID_PREMIUM=price_XXXXXXXXXX_premium
STRIPE_PRICE_ID_ENTERPRISE=price_XXXXXXXXXX_enterprise
TRIAL_DAYS=14
