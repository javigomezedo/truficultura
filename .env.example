DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/truficultura
SECRET_KEY=change-me-in-production-please
# Asistente IA (opcional – sin esto el endpoint /api/assistant/chat devuelve 503)
OPENAI_API_KEY=

# Email / SMTP (opcional — para notificaciones de leads y emails de cuenta)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@truficultura.app
# Dirección de destino para notificaciones de leads (por defecto usa SMTP_FROM)
CONTACT_EMAIL=

# Stripe (pago / suscripción)
# Para desarrollo local: usa test keys (sk_test_...) + Stripe CLI para webhooks
# Para DEV/Staging: usa test keys + registra el endpoint en Stripe Dashboard
# Para Production: usa live keys (sk_live_...)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
TRIAL_DAYS=14
